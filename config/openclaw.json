{
  // Gateway bind to all interfaces (required for Docker)
  "gateway": {
    "bind": "lan"
  },

  // LM Studio as custom provider (OpenAI-compatible)
  "models": {
    "mode": "merge",
    "providers": {
      "lm-studio": {
        "baseUrl": "http://host.docker.internal:1234/v1",
        "apiKey": "${LM_STUDIO_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "qwen/qwen3-8b", "name": "Qwen 3 8B", "contextWindow": 32000, "maxTokens": 4096 },
          { "id": "google/gemma-4-e2b", "name": "Gemma 4 E2B", "contextWindow": 32000, "maxTokens": 4096 },
          { "id": "mistralai/ministral-3-3b-reasoning", "name": "Ministral 3 3B Reasoning", "contextWindow": 32000, "maxTokens": 4096 },
          { "id": "qwen/qwen3.5-4b", "name": "Qwen 3.5 4B", "contextWindow": 32000, "maxTokens": 4096 },
          { "id": "nvidia/nemotron-3-nano-4b", "name": "Nemotron 3 Nano 4B", "contextWindow": 32000, "maxTokens": 4096 }
        ]
      }
    }
  },

  // Default agent model — Qwen3 8B as primary
  "agents": {
    "defaults": {
      "model": {
        "primary": "lm-studio/qwen/qwen3-8b",
        "fallbacks": ["lm-studio/qwen/qwen3.5-4b"]
      }
    }
  },

  // Tools configuration
  "tools": {
    "profile": "coding",
    "allow": ["group:fs", "group:runtime"],
    "web": {
      "search": { "enabled": false },
      "fetch": { "enabled": true, "maxChars": 50000 }
    }
  }
}
